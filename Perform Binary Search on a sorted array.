#include <iostream>
using namespace std;

int main()
{
    int n, item;

    cout << "Enter number of elements: ";
    cin >> n;

    int a[n];

    cout << "Enter sorted elements:\n";
    for(int i = 0; i < n; i++)
    {
        cin >> a[i];
    }

    cout << "Enter element to search: ";
    cin >> item;

    int low = 0, high = n - 1;

    while(low <= high)
    {
        int mid = (low + high) / 2;

        if(a[mid] == item)
        {
            cout << "Element Found at position " << mid;
            return 0;
        }
        else if(a[mid] < item)
        {
            low = mid + 1;
        }
        else
        {
            high = mid - 1;
        }
    }

    cout << "Element Not Found";

    return 0;
}
