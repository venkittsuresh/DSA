#include <iostream>
using namespace std;

int main()
{
    int n, item;

    cout << "Enter number of elements: ";
    cin >> n;

    int a[n];

    cout << "Enter array elements:\n";
    for(int i = 0; i < n; i++)
    {
        cin >> a[i];
    }

    cout << "Enter element to search: ";
    cin >> item;

    for(int i = 0; i < n; i++)
    {
        if(a[i] == item)
        {
            cout << "Element Found at position " << i;
            return 0;
        }
    }

    cout << "Element Not Found";

    return 0;
}
