#include <iostream>
using namespace std;

int main()
{
    int n, searchRoll;

    cout << "Enter number of students: ";
    cin >> n;

    int roll[n];
    string name[n];

    for(int i = 0; i < n; i++)
    {
        cout << "Enter Roll No and Name: ";
        cin >> roll[i] >> name[i];
    }

    cout << "Enter Roll No to search: ";
    cin >> searchRoll;

    for(int i = 0; i < n; i++)
    {
        if(roll[i] == searchRoll)
        {
            cout << "Student Found" << endl;
            cout << "Roll No: " << roll[i] << endl;
            cout << "Name: " << name[i] << endl;
            return 0;
        }
    }

    cout << "Student Not Found";

    return 0;
}
