#include <iostream>
using namespace std;

int main()
{
    int a[3][3], key;

    cout << "Enter 9 elements:\n";

    for(int i = 0; i < 3; i++)
    {
        for(int j = 0; j < 3; j++)
        {
            cin >> a[i][j];
        }
    }

    cout << "Enter element to search: ";
    cin >> key;

    for(int i = 0; i < 3; i++)
    {
        for(int j = 0; j < 3; j++)
        {
            if(a[i][j] == key)
            {
                cout << "Element found at position (" << i << "," << j << ")";
                return 0;
            }
        }
    }

    cout << "Element not found";

    return 0;
}
